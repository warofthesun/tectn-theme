{
    "key": "group_slider_block",
    "title": "Image Slider block",
    "fields": [
        {
            "key": "field_slider_type",
            "label": "Slider style",
            "name": "slider_type",
            "type": "select",
            "instructions": "Table of contents: list left, image right. Horizontal: arrows and dots, optional caption overlay.",
            "choices": {
                "table_of_contents": "Table of contents (list left, image right)",
                "horizontal": "Horizontal",
                "slideshow": "Slideshow"
            },
            "default_value": "table_of_contents",
            "return_format": "value",
            "wrapper": { "width": "", "class": "", "id": "" }
        },
        {
            "key": "field_slider_autoplay",
            "label": "Autoplay",
            "name": "autoplay",
            "type": "true_false",
            "instructions": "Automatically advance slides. Default: No for Table of contents and Horizontal; Yes for Slideshow.",
            "default_value": 0,
            "ui": 1,
            "wrapper": { "width": "", "class": "", "id": "" }
        },
        {
            "key": "field_slider_show_captions",
            "label": "Show captions",
            "name": "show_captions",
            "type": "true_false",
            "instructions": "Show caption and author overlay when the image has them. Off by default for all styles.",
            "default_value": 0,
            "ui": 1,
            "wrapper": { "width": "", "class": "", "id": "" }
        },
        {
            "key": "field_slider_list_icon",
            "label": "List item icon",
            "name": "list_item_icon",
            "type": "font-awesome",
            "instructions": "Optional icon shown next to each list item (e.g. a tree icon). Leave empty for text only.",
            "icon_sets": ["solid", "regular", "brands"],
            "custom_icon_set": "",
            "default_label": "",
            "default_value": "",
            "save_format": "element",
            "allow_null": 1,
            "show_preview": 1,
            "enqueue_fa": 0,
            "allow_in_bindings": 0,
            "fa_live_preview": "",
            "choices": [],
            "conditional_logic": [[{ "field": "field_slider_type", "operator": "==", "value": "table_of_contents" }]],
            "wrapper": { "width": "", "class": "", "id": "" }
        },
        {
            "key": "field_slider_body",
            "label": "Body copy",
            "name": "body",
            "type": "wysiwyg",
            "instructions": "Intro text below the headline (e.g. \"Tree species this year include:\").",
            "tabs": "all",
            "toolbar": "full",
            "media_upload": 1,
            "delay": 0,
            "wrapper": { "width": "", "class": "", "id": "" }
        },
        {
            "key": "field_slider_gallery",
            "label": "Gallery",
            "name": "gallery",
            "type": "gallery",
            "instructions": "Add images. Each image's title becomes a clickable list item; clicking shows that image. Order determines list order.",
            "return_format": "array",
            "preview_size": "medium",
            "library": "all",
            "min": 1,
            "wrapper": { "width": "", "class": "", "id": "" }
        }
    ],
    "location": [[{ "param": "block", "operator": "==", "value": "tectn\/slider" }]],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "hide_on_screen": "",
    "active": true,
    "description": "",
    "show_in_rest": 0
}
