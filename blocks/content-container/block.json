{
  "name": "tectn/content-container",
  "title": "Content container",
  "description": "Container holding two stacked Text + Image blocks with optional background",
  "style": ["file:../library/css/style.css"],
  "category": "tectn-blocks",
  "icon": "admin-comments",
  "keywords": ["card", "text", "steps", "container"],
  "acf": {
    "mode": "preview",
    "renderTemplate": "content_container.php"
  },
  "attributes": {
    "tectnInsideContainer": {
      "type": "boolean",
      "default": true
    }
  },
  "providesContext": {
    "tectn/insideContainer": "tectnInsideContainer"
  },
  "supports": {
    "jsx": true,
    "anchor": true
  },
  "example": {
    "attributes": {
      "mode": "preview",
      "data": { "inserter_preview": true }
    }
  }
}
