{
  "name": "tectn/content-section",
  "title": "Content Section",
  "description": "Full-width section with optional background (image + overlay or solid color), any content, and configurable min height. Optional top or bottom curves.",
  "style": ["file:../library/css/style.css"],
  "editorScript": "file:./content-section-editor.js",
  "category": "tectn-blocks",
  "icon": "layout",
  "keywords": ["section", "background", "content", "container"],
  "acf": {
    "mode": "preview",
    "renderTemplate": "content_section.php"
  },
  "attributes": {
    "tectnInsideContainer": {
      "type": "boolean",
      "default": true
    }
  },
  "providesContext": {
    "tectn/insideContainer": "tectnInsideContainer"
  },
  "supports": {
    "jsx": true,
    "anchor": true,
    "align": ["full", "wide"]
  },
  "example": {
    "attributes": {
      "mode": "preview",
      "data": { "inserter_preview": true }
    }
  }
}