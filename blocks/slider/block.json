{
  "name": "tectn/slider",
  "title": "Image Slider",
  "description": "Multiple slider types available. Use the 'Slider style' dropdown to change your selection.",
  "style": ["file:../../library/css/style.css", "file:./style.css"],
  "viewScript": ["file:./view.js"],
  "category": "tectn-blocks",
  "icon": "slides",
  "keywords": ["slider", "gallery", "table of contents", "toc"],
  "attributes": {
    "inserterPreview": {
      "type": "boolean",
      "default": false
    }
  },
  "acf": {
    "mode": "preview",
    "renderTemplate": "slider.php"
  },
  "supports": {
    "jsx": true,
    "anchor": true,
    "align": ["full", "wide"]
  },
  "variations": [
    {
      "name": "table-of-contents",
      "title": "Menu-style slider",
      "description": "List left, image right.",
      "attributes": {
        "data": {
          "slider_type": "table_of_contents"
        }
      },
      "scope": ["inserter"],
      "isDefault": true,
      "example": {
        "attributes": {
          "mode": "preview",
          "inserterPreview": true,
          "data": {
            "slider_type": "table_of_contents"
          }
        }
      }
    },
    {
      "name": "horizontal",
      "title": "Horizontal slider",
      "description": "Arrows and dots; optional captions.",
      "attributes": {
        "data": {
          "slider_type": "horizontal"
        }
      },
      "scope": ["inserter"],
      "example": {
        "attributes": {
          "mode": "preview",
          "inserterPreview": true,
          "data": {
            "slider_type": "horizontal"
          }
        }
      }
    },
    {
      "name": "slideshow",
      "title": "Slideshow (square crop)",
      "description": "Centered slideshow with square images.",
      "attributes": {
        "data": {
          "slider_type": "slideshow"
        }
      },
      "scope": ["inserter"],
      "example": {
        "attributes": {
          "mode": "preview",
          "inserterPreview": true,
          "data": {
            "slider_type": "slideshow"
          }
        }
      }
    }
  ]
}
